# ── Control plane DB (puzzles, players, ghost_runs, leaderboards) ──────────────
# Local dev: both planes share the same SQLite file
CONTROL_DATABASE_URL=file:./local.db
# CONTROL_DATABASE_AUTH_TOKEN=

# Production (Turso remote)
# CONTROL_DATABASE_URL=libsql://your-control-db.turso.io
# CONTROL_DATABASE_AUTH_TOKEN=your-token

# ── User data plane DB (ranked_matches, daily_completions) ─────────────────────
# Local dev: same file as control (single-DB mode)
USER_DATABASE_URL=file:./local.db
# USER_DATABASE_AUTH_TOKEN=

# Production: separate pool DB(s) — each pool DB stores a subset of users
# USER_DATABASE_URL=libsql://your-pool-db.turso.io
# USER_DATABASE_AUTH_TOKEN=your-pool-token

# ── Fallback (if CONTROL_DATABASE_URL / USER_DATABASE_URL are unset) ───────────
DATABASE_URL=file:./local.db

# ── Auth (Kinde) ───────────────────────────────────────────────────────────────
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://your-domain.kinde.com
KINDE_SITE_URL=http://localhost:3000
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/dashboard

# ── Replay storage (Cloudflare R2) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ranked-sudoku-replays
